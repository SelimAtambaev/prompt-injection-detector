# Copy to .env and fill in. .env is gitignored and must never be committed.

# --- OpenAI (Phase 1) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Detection thresholds (placeholders, tuned in Phase 4) ---
BLOCK_THRESHOLD=0.85
FLAG_THRESHOLD=0.50

# --- Logging: full | truncated | hashed ---
PROMPT_LOG_MODE=truncated
PROMPT_LOG_MAX_CHARS=200
